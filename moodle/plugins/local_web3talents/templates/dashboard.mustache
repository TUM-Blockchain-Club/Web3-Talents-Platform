{{!
    This file is part of Moodle - http://moodle.org/

    @template local_web3talents/dashboard
}}
<section class="local-web3talents-dashboard">
    <p class="lead">{{intro}}</p>
    <dl class="row">
        <dt class="col-sm-3">{{courselabel}}</dt>
        <dd class="col-sm-9">
            {{#coursefound}}
                {{coursename}} <code>{{courseshortname}}</code>
            {{/coursefound}}
            {{^coursefound}}
                <code>{{courseshortname}}</code>
            {{/coursefound}}
        </dd>
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            {{#enabled}}
                <span class="badge text-bg-success">{{status}}</span>
            {{/enabled}}
            {{^enabled}}
                <span class="badge text-bg-secondary">{{status}}</span>
            {{/enabled}}
        </dd>
    </dl>
    {{^coursefound}}
        <div class="alert alert-warning">{{coursenotfound}}</div>
    {{/coursefound}}

    <h3>{{workflowlabel}}</h3>
    <p class="d-flex gap-2 flex-wrap mb-4">
        {{#workflowlinks}}
            <a class="btn {{#primary}}btn-primary{{/primary}}{{^primary}}btn-secondary{{/primary}}" href="{{url}}">{{label}}</a>
        {{/workflowlinks}}
    </p>

    <h3>{{courseadminlabel}}</h3>
    <p class="d-flex gap-2 flex-wrap mb-4">
        {{#courselinks}}
            <a class="btn {{#primary}}btn-primary{{/primary}}{{^primary}}btn-secondary{{/primary}}" href="{{url}}">{{label}}</a>
        {{/courselinks}}
    </p>

    <h3>{{systemlabel}}</h3>
    <p class="d-flex gap-2 flex-wrap mb-4">
        {{#systemlinks}}
            <a class="btn btn-secondary" href="{{url}}">{{label}}</a>
        {{/systemlinks}}
    </p>

    <h3>{{viewlinkslabel}}</h3>
    <p class="d-flex gap-2 flex-wrap">
        {{#viewlinks}}
            <a class="btn btn-secondary" href="{{url}}">{{label}}</a>
        {{/viewlinks}}
    </p>
</section>
